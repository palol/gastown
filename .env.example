# Core identity + workspace
GIT_USER="<your name>"
GIT_EMAIL="<your email>"
FOLDER="/Users/you/gt"

# Optional: host port for web dashboard/feed UI
DASHBOARD_PORT=8080

# Work-hours throttle profile (lighter resources)
GASTOWN_WORK_CPUS=1.5
GASTOWN_WORK_CPU_SHARES=128
GASTOWN_WORK_MEMORY=20g
GASTOWN_WORK_MEMORY_SWAP=20g

# Off-hours profile (faster background progress)
# Leave CPUS blank to auto-use host logical CPU count.
GASTOWN_OFFHOURS_CPUS=
GASTOWN_OFFHOURS_CPU_SHARES=1024
GASTOWN_OFFHOURS_MEMORY=20g
GASTOWN_OFFHOURS_MEMORY_SWAP=20g

# Work-hour schedule (launchd helper uses these)
GASTOWN_WORK_START=09:00
GASTOWN_OFFHOURS_START=18:00
GASTOWN_WORK_WEEKDAYS=1,2,3,4,5

# Optional secrets for tools inside container
# GITHUB_TOKEN=""
# GH_TOKEN=""
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# GEMINI_API_KEY=""
