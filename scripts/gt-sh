#!/bin/sh
# Thin wrapper for Claude Code hooks: routes gt commands into the running gastown-sandbox
# container where Dolt (port 3307) is accessible. Used instead of the local binary because
# hooks run in /bin/sh (no zsh docker-compose function available) and the host binary
# can't reach the containerized Dolt server.
#
# Translates host cwd ($HOME/gt/...) to container path (/gt/...) so gt can detect
# the agent role from the working directory.
# Container name defined in ~/workspace/gastown/docker-compose.yml; override via GT_CONTAINER
GT_CONTAINER="${GT_CONTAINER:-gastown-sandbox}"
case "$PWD" in
  "$HOME/gt"*)
    CONTAINER_CWD=$(printf '%s' "$PWD" | sed "s|^$HOME/gt|/gt|")
    exec docker exec -w "$CONTAINER_CWD" "$GT_CONTAINER" gt "$@"
    ;;
  *)
    exec docker exec "$GT_CONTAINER" gt "$@"
    ;;
esac
